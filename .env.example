# .env.example
# ──────────────────────────────────────────────────────────────────────
# Copy this to .env in each service folder and fill in the values.
# NEVER commit .env files to git.
# ──────────────────────────────────────────────────────────────────────

# ── Realtime server (realtime-server/.env) ───────────────────────────
PORT=8001
BACKEND_URL=http://localhost:8000

# ── Signaling server (telemedicine/signaling/.env) ───────────────────
PORT=3001

# ── Frontend (frontend/.env) ─────────────────────────────────────────
# For local dev:
REACT_APP_BACKEND_URL=http://localhost:8000
REACT_APP_REALTIME_WS_URL=ws://localhost:8001
REACT_APP_SIGNALING_URL=http://localhost:3001

# For production (replace with your deployed URLs):
# REACT_APP_BACKEND_URL=https://gis-backend.up.railway.app
# REACT_APP_REALTIME_WS_URL=wss://gis-realtime.up.railway.app
# REACT_APP_SIGNALING_URL=https://gis-signaling.up.railway.app
